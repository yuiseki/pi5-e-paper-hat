# pi5-e-paper-hat 設定 (このファイルをコピーして .env を作る)
# cp .env.example .env

# --- Wi-Fi AP (オンボーディング QR 用) ---
WIFI_SSID=pi5-w-1
WIFI_PSK=your-wifi-passphrase
WELCOME_URL=https://yuiseki.dev/welcome

# --- 地図 ---
MAP_URL=https://yuiseki.dev/static/epaper-map.html
MAP_ZOOM=15.5

# --- traccar (pi-z2-wh 現在地追従) ---
TRACCAR_API=http://localhost:30082
TRACCAR_USER=admin@traccar.local
TRACCAR_PASSWORD=your-traccar-password
TRACCAR_DEVICE_ID=1

# --- ハードウェア ---
EPAPER_LIB=/home/yuiseki/src/e-Paper/RaspberryPi_JetsonNano/python/lib
